# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
MODEL_DEPLOYMENT_NAME=your_model_deployment_name

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional: currently read in code, but not actively applied by YOLO loader
YOLO_MODEL_PATH=yolov8n.pt

# Prompt filtering to reduce noisy/low-confidence object mentions
LLM_MIN_CONFIDENCE=0.45
LLM_MAX_OBJECTS=4

# LLM comparison harness (Azure AI Foundry OpenAI-compatible endpoint)
# Example format:
# https://samjswag-6951-resource.services.ai.azure.com/openai/v1/
AZURE_FOUNDRY_OPENAI_BASE_URL=
AZURE_FOUNDRY_API_KEY=
AZURE_DEPLOYMENT_GPT_4O_MINI=
